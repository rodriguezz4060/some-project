generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model BzvpPersonnel {
  id                  Int      @id @default(autoincrement())
  fullName            String
  rank                String
  birthDate           String
  birthPlace          String?
  photo               String?
  passport            String?
  passportIssued      String?
  tin                 String?
  militaryId          String?
  militaryIdIssued    String?
  ubd                 String?
  ubdDate             String?
  serviceUnit         String?
  serviceYears        String?
  civilianJob         String?
  education           String?
  actualAddress       String?
  registrationAddress String?
  driverLicense       String?
  criminalRecord      String?
  policeRecords       String?
  family              String?
  phone               String?
  relativePhones      String?
  personalOrder       String?
  conscription        String?
  health              String?
  healthComplaints    String?
  moralState          String?
  bloodType           String?
  shoeSize            String?
  notes               String?
  status              String
  arrivalDate         String
  trainingPeriod      String
  specialization      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
}

model MilitaryPersonnel {
  id             Int      @id @default(autoincrement())
  fullName       String
  rank           String
  position       String
  unit           String
  status         String
  birthDate      String
  photo          String?
  experience     Int?
  missions       Int?
  phone          String?
  email          String?
  lastActiveDays Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  medicalRecords  MedicalRecord[]
  achievements    Achievement[]
  equipment       Equipment[]
  positionHistory PositionEntry[]
  clothingSizes   ClothingSizes?

  @@index([status])
}

model MedicalRecord {
  id            Int     @id @default(autoincrement())
  condition     String
  diagnosisDate String
  status        String
  notes         String?
  personnelId   Int
  personnel   MilitaryPersonnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
}

enum Role {
  admin
  moderator
  user
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(user)
  auditLogs   AuditLog[]
  photos      Photo[]
  fuelRecords FuelRecord[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Achievement {
  id          Int     @id @default(autoincrement())
  name        String
  date        String
  type        String
  description String?
  personnelId Int
  personnel   MilitaryPersonnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
}

model Equipment {
  id           Int     @id @default(autoincrement())
  name         String
  type         String
  serialNumber String?
  issuedDate   String
  personnelId  Int
  personnel    MilitaryPersonnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
}

model PositionEntry {
  id          Int     @id @default(autoincrement())
  position    String
  unit        String
  startDate   String
  endDate     String?
  personnelId Int
  personnel   MilitaryPersonnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
}

model ClothingSizes {
  id          Int     @id @default(autoincrement())
  height      String?
  chest       String?
  waist       String?
  shoes       String?
  headgear    String?
  uniform     String?
  personnelId Int     @unique
  personnel   MilitaryPersonnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
}

model Photo {
  id         Int      @id @default(autoincrement())
  filename   String
  original   String
  width      Int
  height     Int
  uploadedAt DateTime @default(now())
  uploaderId Int
  uploader   User     @relation(fields: [uploaderId], references: [id])
  detections Detection[]
}

model Detection {
  id         Int     @id @default(autoincrement())
  photoId    Int
  photo      Photo   @relation(fields: [photoId], references: [id], onDelete: Cascade)
  label      String
  confidence Float
  x1         Float
  y1         Float
  x2         Float
  y2         Float
}

model Vehicle {
  id           Int      @id @default(autoincrement())
  brand       String
  model       String
  licensePlate String  @unique
  type        String
  year        Int?
  vin         String?
  fuelType    String
  tankCapacity Int?
  unit        String
  notes       String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fuelRecords FuelRecord[]
}

model FuelRecord {
  id            Int      @id @default(autoincrement())
  vehicleId     Int
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date          String
  fuelType      String
  liters        Float
  pricePerLiter Float?
  totalCost     Float?
  mileage       Int?
  driverName    String
  invoiceNumber String?
  supplier      String?
  purpose       String?
  createdById   Int
  createdBy     User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([vehicleId])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    Int?
  description String
  changes     Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
